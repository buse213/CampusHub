<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- MODERN AVATAR ALANI -->
        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="16dp">

            <!-- Renkli Daire Arka Planı -->
            <View
                android:id="@+id/viewAvatarArkaPlan"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_background_purple" />

            <!-- Kullanıcının Baş Harfi -->
            <TextView
                android:id="@+id/txtAvatarHarf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text=" "
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- KULLANICI BİLGİLERİ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtSohbetKisi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kullanıcı Adı"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/txtSonMesaj"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Son mesaj buraya gelecek..."
                android:textSize="14sp"
                android:textColor="#777777"
                android:maxLines="1"
                android:layout_marginTop="2dp"
                android:ellipsize="end"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>