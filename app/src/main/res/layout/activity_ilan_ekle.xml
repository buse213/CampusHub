<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"> <!-- Arka planı beyaz yaparak karanlık mod sorununu önledik -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ÜST BAR: GERİ BUTONU VE BAŞLIK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- İŞTE EKSİK OLAN BUTON BURASI -->
            <ImageButton
                android:id="@+id/btnGeri"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Geri Dön"
                app:tint="#8A2BE2" />

            <TextView
                android:id="@+id/txtAnaBaslik"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yeni İlan Oluştur"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:textColor="#8A2BE2"/>
        </LinearLayout>

        <EditText
            android:id="@+id/editBaslik"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="İlan Başlığı"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/editFiyat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fiyat (TL)"
            android:inputType="numberDecimal"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <Spinner
            android:id="@+id/spinnerKategori"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/editAciklama"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="İlan Açıklaması"
            android:gravity="top"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:layout_marginBottom="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="15dp">

            <Button
                android:id="@+id/btnFotoSec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷 Fotoğraf Seç"
                android:textAllCaps="false"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white" />

            <ImageView
                android:id="@+id/imgIlanFoto"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="15dp"
                android:scaleType="centerCrop"
                android:background="#E0E0E0"
                android:src="@android:drawable/ic_menu_camera" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnKonumAl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Konum Ekle"
                android:textAllCaps="false"
                android:backgroundTint="#FF9800"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/txtKonumDurum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Konum seçilmedi"
                android:textColor="#757575"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnIlanKaydet"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="İlanı Yayınla"
            android:backgroundTint="@color/purple_500"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="10dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>