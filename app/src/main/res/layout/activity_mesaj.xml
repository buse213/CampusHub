<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"> <!-- Beyaz arka plan ile netlik sağladık -->

    <!-- Mesajların Listelendiği Alan -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMesajlar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutMesajGonder"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Mesaj Gönderme Çubuğu (Modern Pill Tasarımı) -->
    <LinearLayout
        android:id="@+id/layoutMesajGonder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <!-- Modern Mesaj Giriş Kutusu -->
        <EditText
            android:id="@+id/editMesaj"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Mesaj yazın..."
            android:textColorHint="#757575"
            android:textColor="#212121"
            android:background="@drawable/edittext_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="50dp"
            android:textSize="16sp" />

        <!-- Gönder Butonu (Mor Daire Tasarımı) -->
        <ImageButton
            android:id="@+id/btnGonder"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="#FFFFFF"
            android:background="@drawable/circle_background_purple"
            android:elevation="2dp"
            android:contentDescription="Mesaj Gönder" />

    </LinearLayout>
</RelativeLayout>