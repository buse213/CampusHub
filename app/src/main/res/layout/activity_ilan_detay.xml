<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ÜST PANEL: Geri Butonu ve Başlık -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnGeri"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow"
                android:contentDescription="Geri Dön"
                app:tint="#333333" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İlan Detayı"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- ÇOKLU RESİM KAYDIRICI ALANI -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerGorseller"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- GÜNCELLENEN TABLAYOUT: Noktalar burada küçültüldü -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutDots"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/dot_selector"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="10dp"
                app:tabMinWidth="10dp"
                app:tabPaddingStart="0dp"
                app:tabPaddingEnd="0dp"
                app:tabMode="fixed"
                app:tabRippleColor="@null"
                app:tabIndicatorFullWidth="false" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/txtDetayBaslik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="İlan Başlığı"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/txtDetayFiyat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.000 TL"
                android:textColor="@color/purple_500"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginVertical="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Açıklama"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtDetayAciklama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="İlan açıklaması buraya gelecek..."
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Konum"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="20dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="15dp"
                app:cardElevation="4dp">

                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnSaticiMesaj"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Satıcıya Mesaj Gönder"
                android:layout_marginTop="30dp"
                android:backgroundTint="@color/purple_500"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/layoutSahipButonlari"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="30dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnIlanGuncelle"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="Güncelle"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#8A2BE2"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnIlanSil"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="Sil"
                    android:backgroundTint="#FF4500"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>